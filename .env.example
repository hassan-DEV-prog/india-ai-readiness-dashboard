# Project environment: development | staging | production
APP_ENV=development

# Logging level override (optional; falls back to settings.yaml)
# LOG_LEVEL=DEBUG

# Streamlit Cloud secrets (if using paid APIs in future)
# MAPBOX_TOKEN=your_mapbox_token_here
